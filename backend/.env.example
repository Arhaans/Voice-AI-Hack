DEEPGRAM_API_KEY=your_deepgram_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# TTS provider toggle
# Use "gradium" to switch to Gradium, or "elevenlabs" to revert.
TTS_PROVIDER=gradium

# Gradium TTS
GRADIUM_API_KEY=your_gradium_api_key
GRADIUM_VOICE_ID=your_gradium_voice_id
# Optional Gradium overrides
# GRADIUM_MODEL=default
# GRADIUM_TTS_URL=wss://eu.api.gradium.ai/api/speech/tts

# ElevenLabs fallback
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Optional overrides
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# DEEPGRAM_MODEL=nova-3
# ELEVENLABS_MODEL=eleven_flash_v2_5
